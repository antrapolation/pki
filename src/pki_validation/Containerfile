# ── Stage 1: Build ────────────────────────────────────────────────────
FROM docker.io/hexpm/elixir:1.18.4-erlang-27.3.4.6-debian-trixie-20260223 AS build

RUN apt-get update && apt-get install -y git make gcc && rm -rf /var/lib/apt/lists/*

WORKDIR /app
ENV MIX_ENV=prod

RUN mix local.hex --force && mix local.rebar --force

COPY src/pki_validation/mix.exs src/pki_validation/
COPY src/pki_crypto/mix.exs src/pki_crypto/
COPY src/pki_platform_engine/mix.exs src/pki_platform_engine/
COPY src/keyx/mix.exs src/keyx/

# Copy path dep source (needed before deps.get)
COPY src/pki_crypto/lib src/pki_crypto/lib
COPY src/pki_platform_engine/lib src/pki_platform_engine/lib
COPY src/pki_platform_engine/config src/pki_platform_engine/config
COPY src/pki_platform_engine/priv src/pki_platform_engine/priv
COPY src/keyx/lib src/keyx/lib

RUN cd src/pki_validation && mix deps.get --only prod

COPY src/pki_validation/lib src/pki_validation/lib
COPY src/pki_validation/config src/pki_validation/config
COPY src/pki_validation/priv src/pki_validation/priv

RUN cd src/pki_validation && mix compile && mix release

# ── Stage 2: Runtime ─────────────────────────────────────────────────
FROM docker.io/debian:trixie-20260223-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends libstdc++6 openssl ca-certificates tini && \
    rm -rf /var/lib/apt/lists/* && \
    groupadd -r pki && useradd -r -g pki -d /app -s /usr/sbin/nologin pki

WORKDIR /app
COPY --from=build --chown=pki:pki /app/src/pki_validation/_build/prod/rel/pki_validation ./

USER pki
ENV RELEASE_DISTRIBUTION=name
ENV PORT=4005
EXPOSE 4005

ENTRYPOINT ["tini", "--"]
CMD ["bin/pki_validation", "start"]
