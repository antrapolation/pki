# ── Stage 1: Build ────────────────────────────────────────────────────
FROM docker.io/hexpm/elixir:1.18.4-erlang-27.3.4.6-debian-trixie-20260223 AS build

RUN apt-get update && apt-get install -y git make gcc && rm -rf /var/lib/apt/lists/*

WORKDIR /app
ENV MIX_ENV=prod

RUN mix local.hex --force && mix local.rebar --force

# Copy mix files for dependency resolution (including path deps)
COPY src/pki_ca_engine/mix.exs src/pki_ca_engine/
COPY src/pki_audit_trail/mix.exs src/pki_audit_trail/
COPY src/keyx/mix.exs src/keyx/
COPY src/x509/mix.exs src/x509/
COPY src/ex_ccrypto/mix.exs src/ex_ccrypto/

# Copy path dep source (needed before deps.get for path resolution)
COPY src/keyx/lib src/keyx/lib
COPY src/x509/lib src/x509/lib
COPY src/ex_ccrypto/lib src/ex_ccrypto/lib

# Fetch deps
RUN cd src/pki_ca_engine && mix deps.get

# Copy main service source
COPY src/pki_ca_engine/lib src/pki_ca_engine/lib
COPY src/pki_ca_engine/config src/pki_ca_engine/config
COPY src/pki_ca_engine/priv src/pki_ca_engine/priv
COPY src/pki_audit_trail/lib src/pki_audit_trail/lib
COPY src/pki_audit_trail/config src/pki_audit_trail/config
COPY src/pki_audit_trail/priv src/pki_audit_trail/priv

# Compile and build release
RUN cd src/pki_ca_engine && mix deps.compile && mix compile && mix release

# ── Stage 2: Runtime ─────────────────────────────────────────────────
FROM docker.io/debian:trixie-20260223-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends libstdc++6 openssl ca-certificates tini && \
    rm -rf /var/lib/apt/lists/* && \
    groupadd -r pki && useradd -r -g pki -d /app -s /usr/sbin/nologin pki

WORKDIR /app
COPY --from=build --chown=pki:pki /app/src/pki_ca_engine/_build/prod/rel/pki_ca_engine ./

USER pki
ENV RELEASE_DISTRIBUTION=name
ENV PORT=4001
EXPOSE 4001

ENTRYPOINT ["tini", "--"]
CMD ["bin/pki_ca_engine", "start"]
