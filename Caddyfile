# Caddy reverse proxy for PKI Certificate Authority System
#
# Required environment variables (set in /opt/pki/.env):
#   PLATFORM_HOST      - Platform admin portal domain  (e.g. admin.straptrust.com)
#   CADDY_ACME_EMAIL   - Email for Let's Encrypt ACME registration
#
# Tenant routing is NOT configured here — it is managed dynamically by
# PkiPlatformEngine.CaddyConfigurator via the Caddy admin API at
# localhost:2019. When a tenant is provisioned, routes for:
#   <slug>.ca.<base_domain>   → localhost:<tenant-port>
#   <slug>.ra.<base_domain>   → localhost:<tenant-port>
#   <slug>.ocsp.<base_domain> → localhost:<tenant-port>
# are added automatically. Deprovision removes them.

{
    # Admin API must be enabled — CaddyConfigurator uses it to add/remove
    # tenant reverse-proxy routes at runtime without a Caddy reload.
    admin localhost:2019

    email {$CADDY_ACME_EMAIL:admin@example.com}
}

# Platform admin portal — static, always present
{$PLATFORM_HOST:admin.pki.local} {
    reverse_proxy localhost:4006 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
    }

    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
