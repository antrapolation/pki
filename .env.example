# PKI CA System — Environment Variables
# Copy to .env and change ALL values before deployment!

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Database URLs (one per service) ─────────────────────────────────
# Replace CHANGE_ME_strong_password_here with your actual POSTGRES_PASSWORD
CA_ENGINE_DATABASE_URL=ecto://postgres:CHANGE_ME_strong_password_here@postgres:5432/pki_ca_engine
RA_ENGINE_DATABASE_URL=ecto://postgres:CHANGE_ME_strong_password_here@postgres:5432/pki_ra_engine
VALIDATION_DATABASE_URL=ecto://postgres:CHANGE_ME_strong_password_here@postgres:5432/pki_validation
PLATFORM_DATABASE_URL=ecto://postgres:CHANGE_ME_strong_password_here@postgres:5432/pki_platform

# ── SoftHSM2 ────────────────────────────────────────────────────────
SOFTHSM_TOKEN_LABEL=PkiCA
SOFTHSM_SO_PIN=CHANGE_ME_8_digit_so_pin
SOFTHSM_USER_PIN=CHANGE_ME_user_pin
HSM_PIN=CHANGE_ME_user_pin

# ── Secrets ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
SECRET_KEY_BASE=CHANGE_ME_generate_with_openssl_rand_base64_64
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# ── Portal hostnames ────────────────────────────────────────────────
# Set to your production domains (used by Phoenix for WebSocket origin check)
PHX_HOST=localhost
CA_PORTAL_HOST=localhost
RA_PORTAL_HOST=localhost
PLATFORM_PORTAL_HOST=localhost

# ── Platform admin ──────────────────────────────────────────────────
PLATFORM_ADMIN_USERNAME=admin
PLATFORM_ADMIN_PASSWORD=CHANGE_ME_platform_admin_password
