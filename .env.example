# PKI CA System — Environment Variables
# Copy to .env and change ALL values before deployment!
#
#   cp .env.example .env
#   # then edit .env with your secrets
#
# Generate secrets:
#   openssl rand -base64 64   # SECRET_KEY_BASE
#   openssl rand -base64 32   # INTERNAL_API_SECRET, signing salts
#   openssl rand -hex 4       # HSM PINs

# ── Architecture Mode ────────────────────────────────────────────────────
# "direct" = single BEAM node, portals call engines in-process (no HTTP between services)
# Remove or set empty for multi-node HTTP mode
ENGINE_CLIENT_MODE=direct

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32

# SoftHSM2 (dev only — replace with real HSM config in production)
SOFTHSM_TOKEN_LABEL=PkiCA
SOFTHSM_SO_PIN=CHANGE_ME
SOFTHSM_USER_PIN=CHANGE_ME

# Session signing — generate with: openssl rand -base64 64
SECRET_KEY_BASE=CHANGE_ME_generate_with_openssl_rand_base64_64

# Internal API secret — shared between RA Engine and CA Engine
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_32

# Platform admin — initial super_admin credentials (used on first /setup)
PLATFORM_ADMIN_USERNAME=trust_admin
PLATFORM_ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password

# Portal hostnames (used by Caddy and each portal's endpoint URL)
PHX_HOST=example.com
CA_PORTAL_HOST=ca.example.com
RA_PORTAL_HOST=ra.example.com
PLATFORM_HOST=admin.example.com

# ── Portal URL (for invitation emails) ──────────────────
PLATFORM_PORTAL_URL=https://admin.example.com

# Caddy ACME / Let's Encrypt
CADDY_ACME_EMAIL=admin@example.com

# Session signing salts — rotate these if a salt is ever exposed
# Generate new ones with: openssl rand -base64 32
CA_PORTAL_SIGNING_SALT=CHANGE_ME_generate_with_openssl_rand_base64_32
RA_PORTAL_SIGNING_SALT=CHANGE_ME_generate_with_openssl_rand_base64_32
RA_PORTAL_ENCRYPTION_SALT=CHANGE_ME_generate_with_openssl_rand_base64_32
PLATFORM_SIGNING_SALT=CHANGE_ME_generate_with_openssl_rand_base64_32

# ── Database (PostgreSQL on localhost) ───────────────────
# Use port 6432 if PgBouncer is installed, otherwise 5432 for direct PostgreSQL
CA_ENGINE_DATABASE_URL=ecto://postgres:YOUR_PG_PASSWORD@localhost:6432/pki_ca_engine
RA_ENGINE_DATABASE_URL=ecto://postgres:YOUR_PG_PASSWORD@localhost:6432/pki_ra_engine
VALIDATION_DATABASE_URL=ecto://postgres:YOUR_PG_PASSWORD@localhost:6432/pki_validation
PLATFORM_DATABASE_URL=ecto://postgres:YOUR_PG_PASSWORD@localhost:6432/pki_platform

# ── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=re_CHANGE_ME
MAILER_FROM="PQC PKI Platform <noreply@example.com>"

# ── Service Ports ────────────────────────────────────────────────────────
CA_ENGINE_PORT=4001
CA_PORTAL_PORT=4002
RA_ENGINE_PORT=4003
RA_PORTAL_PORT=4004
VALIDATION_PORT=4005
PLATFORM_PORTAL_PORT=4006

# ── Internal Service URLs (only needed if ENGINE_CLIENT_MODE is NOT direct)
CA_ENGINE_URL=http://127.0.0.1:4001
RA_ENGINE_URL=http://127.0.0.1:4003
VALIDATION_URL=http://127.0.0.1:4005

# ── Connection Pools ────────────────────────────────────────────────────
# Engine main repos (CA, RA)
POOL_SIZE=10
# Per-tenant dynamic repos (ca_repo, ra_repo, audit_repo per tenant — 3 pools × this value)
TENANT_POOL_SIZE=5
# Platform registry repo
PLATFORM_POOL_SIZE=5
# Audit trail repo
AUDIT_POOL_SIZE=5
# Validation service repo
VALIDATION_POOL_SIZE=20

# ── Security ────────────────────────────────────────────────────────────
COOKIE_SECURE=true

# ── HSM ─────────────────────────────────────────────────────────────────
SOFTHSM2_CONF=/home/pki/softhsm2.conf
